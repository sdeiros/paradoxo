<style>
  .container {
    max-width: 1350px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Hero ── */
  .hero {
    background-color: #c50066;
    padding: 8rem 0 4rem;
    min-height: 500px;
  }

  .hero .container {
    display: flex;
    align-items: flex-end;
    height: 100%;
  }

  .hero-title {
    font-size: clamp(1.75rem, 4vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -1px;
    color: #fff;
    max-width: 60%;
    margin: 0;
  }

  .highlight {
    color: #ffed00;
  }

  /* ── Content ── */
  .content {
    background: #fff;
    border-radius: 2rem 2rem 0 0;
    margin-top: -2rem;
    position: relative;
    z-index: 1;
    padding: 4rem 0 5rem;
  }

  /* ── Headings & paragraphs ── */
  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #000;
    margin: 2.5rem 0 0.75rem;
    letter-spacing: -0.5px;
  }

  h2:first-of-type {
    margin-top: 0;
  }

  p {
    color: #000;
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  /* ── Section image ── */
  .section-image {
    margin: 1.5rem 0 2.5rem;
  }

  .section-image img {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    display: block;
  }

  /* ── Carousel ── */
  .carousel-wrapper {
    position: relative;
    margin-top: 1rem;
    margin-bottom: 1rem;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: 2px solid #000;
    background: #fff;
    color: #000;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    z-index: 10;
    flex-shrink: 0;
  }

  .carousel-btn--prev { left: -1.25rem; }
  .carousel-btn--next { right: -1.25rem; }

  .carousel-btn:hover {
    background: #c50066;
    color: #fff;
    border-color: #c50066;
  }

  .carousel-track {
    overflow: hidden;
  }

  .team-cards {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 6px;
  }

  .team-cards::-webkit-scrollbar {
    display: none;
  }

  /* ── Team card ── */
  .card {
    border: 2px solid #e8e8e8;
    border-radius: 1.25rem;
    background: #fff;
    display: flex;
    flex-direction: column;
    flex: 0 0 320px;
    scroll-snap-align: start;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
    border-color: #c50066;
  }

  .card-photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    flex-shrink: 0;
  }

  .card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .card:hover .card-photo img {
    transform: scale(1.04);
  }

  .card-content {
    padding: 1.25rem 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    border-top: 2px solid #f0f0f0;
  }

  .card-content h3 {
    margin: 0 0 0.4rem;
    font-size: 1.35rem;
    font-weight: 700;
    color: #000;
    letter-spacing: -0.5px;
  }

  .card-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    background: #c50066;
    padding: 0.25rem 0.65rem;
    border-radius: 2rem;
    margin-bottom: 0.85rem;
    align-self: flex-start;
  }

  .card-description {
    font-size: 0.9rem;
    font-weight: 400;
    color: #444;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Animations ── */

  /* Hero title word-by-word reveal */
  .hero-title .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(24px);
    animation: wordReveal 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes wordReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scroll-triggered fade-ins */
  .fade-up {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .fade-left {
    opacity: 0;
    transform: translateX(-28px);
    transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .fade-left.visible {
    opacity: 1;
    transform: translateX(0);
  }

  /* Section image reveal with clip-path */
  .section-image {
    overflow: hidden;
  }

  .section-image img {
    clip-path: inset(100% 0 0 0);
    transition: clip-path 0.9s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    transform: scale(1.06);
  }

  .section-image.visible img {
    clip-path: inset(0% 0 0 0);
    transform: scale(1);
  }

  /* Staggered cards */
  .card {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.2s ease,
                border-color 0.2s ease;
  }

  .card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* h2 underline draw */
  h2 {
    position: relative;
    display: inline-block;
  }

  h2::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: #c50066;
    transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  h2.visible::after {
    width: 100%;
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .fade-up, .fade-left, .card, h2::after { transition: none; }
    .section-image img { clip-path: none; transform: none; transition: none; }
    .hero-title .word { animation: none; opacity: 1; transform: none; }
  }
  .dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: #ddd;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }

  .dot--ativo {
    background: #c50066;
    transform: scale(1.25);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hero { padding: 6rem 0 3.5rem; }
  }

  @media (max-width: 768px) {
    .container { padding: 0 1.25rem; }

    .hero { padding: 6rem 0 3rem; min-height: 380px; }
    .hero-title { max-width: 100%; }

    .content { padding: 2.5rem 0 4rem; margin-top: -1.5rem; }

    h2 { font-size: 1.5rem; }
    p { font-size: 1rem; }

    .carousel-btn--prev { left: -0.75rem; }
    .carousel-btn--next { right: -0.75rem; }

    .card { flex: 0 0 calc(80vw - 1.5rem); }
  }

  @media (max-width: 480px) {
    .container { padding: 0 1rem; }

    .hero { padding: 5rem 0 2.5rem; min-height: 320px; }

    .content { border-radius: 1.5rem 1.5rem 0 0; padding: 2rem 0 3rem; }

    h2 { font-size: 1.25rem; }
    p { font-size: 0.95rem; margin-bottom: 1rem; }

    .carousel-btn { display: none; }

    .card { flex: 0 0 calc(100vw - 3.5rem); }

    .card-content h3 { font-size: 1.3rem; }
  }

  @media (max-width: 360px) {
    h2 { font-size: 1.1rem; }
    p { font-size: 0.9rem; }
  }
</style>

<script>
  // ── Hero title: split into words and animate each ──
  const heroTitle = document.querySelector('.hero-title') as HTMLElement;
  if (heroTitle) {
    const html = heroTitle.innerHTML;
    // Split text nodes into word spans, preserve HTML tags
    heroTitle.innerHTML = html.replace(/(<[^>]+>)|([^<>\s]+)/g, (match, tag, word) => {
      if (tag) return tag;
      return `<span class="word">${word}</span> `;
    });
    const words = heroTitle.querySelectorAll('.word');
    words.forEach((w, i) => {
      (w as HTMLElement).style.animationDelay = `${i * 0.07}s`;
    });
  }

  // ── IntersectionObserver for scroll animations ──
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.fade-up, .fade-left, .section-image, h2.fade-left').forEach(el => {
    observer.observe(el);
  });

  // ── Cards: staggered entrance ──
  const cardObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const cards = document.querySelectorAll('.card');
        cards.forEach((card, i) => {
          setTimeout(() => card.classList.add('visible'), i * 80);
        });
        cardObserver.disconnect();
      }
    });
  }, { threshold: 0.1 });

  const firstCard = document.querySelector('.card');
  if (firstCard) cardObserver.observe(firstCard);

  // ── Carousel ──
  const grid = document.getElementById("teamGrid") as HTMLElement;
  const prevBtn = document.getElementById("prevBtn") as HTMLButtonElement;
  const nextBtn = document.getElementById("nextBtn") as HTMLButtonElement;
  const dotBtns = Array.from(document.querySelectorAll(".dot")) as HTMLButtonElement[];

  let currentIndex = 0;

  function getCards(): HTMLElement[] {
    return Array.from(grid.querySelectorAll(".card")) as HTMLElement[];
  }

  function getCardWidth(): number {
    const cards = getCards();
    if (!cards.length) return 280;
    const gap = parseFloat(getComputedStyle(grid).gap) || 20;
    return cards[0].offsetWidth + gap;
  }

  function atualizarDots(index: number) {
    dotBtns.forEach((d, i) => d.classList.toggle("dot--ativo", i === index));
  }

  function scrollToIndex(index: number): void {
    const count = getCards().length;
    currentIndex = ((index % count) + count) % count;
    grid.scrollTo({ left: currentIndex * getCardWidth(), behavior: "smooth" });
    atualizarDots(currentIndex);
  }

  nextBtn?.addEventListener("click", () => scrollToIndex(currentIndex + 1));
  prevBtn?.addEventListener("click", () => scrollToIndex(currentIndex - 1));

  dotBtns.forEach((btn, i) => btn.addEventListener("click", () => scrollToIndex(i)));

  grid.addEventListener("scrollend", () => {
    currentIndex = Math.round(grid.scrollLeft / getCardWidth());
    atualizarDots(currentIndex);
  });
</script>