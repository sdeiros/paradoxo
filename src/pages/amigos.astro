---

<Layout title="Amigos do Paradoxo">
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">
        Você já se perguntou como a Arte pode <span class="highlight">Transformar Vidas e Comunidades</span>?
      </h1>
    </div>
  </section>

  <section class="content">
    <div class="container">
      <h2 class="content-title">A ARTE ACONTECE EM REDE</h2>
      <div class="content-text">
        <p>
          Ser <strong>Amigo do Paradoxo</strong> é caminhar junto com um espaço independente que acredita na arte como ferramenta de encontro, cuidado e transformação.
        </p>
        <p>
          O apoio dos Amigos viabiliza exposições, oficinas, encontros e a manutenção de um espaço acessível para artistas e comunidade na Zona Norte do Rio de Janeiro. Cada contribuição fortalece a continuidade do Paradoxo e garante que a arte siga acontecendo de forma livre, diversa e próxima das pessoas.
        </p>
        <p>
          Ao se tornar Amigo, você apoia não apenas um espaço, mas uma rede de artistas cujos sonhos estão se tornando reais.
        </p>
      </div>
    </div>
  </section>

  <section class="pricing">
    <div class="container">
      <h2 class="pricing-title">COMO APOIAR O PARADOXO?</h2>
      <p class="pricing-subtitle">Escolha como você pode fazer a diferença e ajudar a arte a florescer em nossa comunidade.</p>

      <div class="carousel-wrapper">
        <button class="carousel-btn carousel-btn--prev" id="prevBtn" aria-label="Anterior">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>

        <div class="carousel-track">
          <div class="pricing-grid" id="pricingGrid">
            {planos.map((plano) => (
              <div class={`pricing-card${plano.destaque ? " pricing-card--destaque" : ""}`}>
                {plano.destaque && <div class="destaque-badge">Mais apoiado</div>}
                <div class="card-body">
                  <h3 class="plan-name">{plano.nome.split("\n").map((l, i) => <>{l}{i === 0 && <br/>}</>)}</h3>
                  <ul class="benefits-list">
                    {plano.beneficios.map((b) => <li>{b}</li>)}
                  </ul>
                  {plano.nota12meses && (
                    <p class="nota-12">* Benefícios extras liberados após 12 meses de apoio contínuo.</p>
                  )}
                </div>
                <div class="card-footer">
                  <div class="price-wrapper">
                    <span class="price-label">por mês</span>
                    <span class="price">R${plano.preco}</span>
                  </div>
                  <button
                    class={`btn${plano.destaque ? " btn--destaque" : ""}`}
                    onclick={`window.open('${plano.url}', '_blank')`}
                  >
                    Apoiar este plano
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>

        <button class="carousel-btn carousel-btn--next" id="nextBtn" aria-label="Próximo">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>

      <div class="dots" id="dots">
        {planos.map((_, i) => <button class={`dot${i === 0 ? " dot--ativo" : ""}`} aria-label={`Ir para plano ${i + 1}`} data-index={i}></button>)}
      </div>

      <a href="/colaboracao" class="free-contribution">
        <div class="free-text">
          <h3 class="free-title">Contribuição Livre</h3>
          <p class="free-subtitle">Contribua com o valor que fizer sentido para você</p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 1350px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  .hero {
    background-color: #c50066;
    padding: 8rem 0 4rem;
    min-height: 500px;
  }

  .hero .container {
    display: flex;
    align-items: flex-end;
    height: 100%;
  }

  .hero-title {
    font-size: clamp(1.75rem, 4vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -1px;
    color: #fff;
    max-width: 60%;
  }

  .highlight { color: #ffed00; }

  /* Content */
  .content {
    background: #fff;
    padding: 4rem 0;
    border-radius: 2rem 2rem 0 0;
    margin-top: -2rem;
    position: relative;
    z-index: 1;
  }

  .content-title {
    font-size: 2rem;
    font-weight: 700;
    color: #000;
    margin-bottom: 1rem;
    letter-spacing: -0.5px;
  }

  .content-text p {
    color: #000;
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.7;
    margin-bottom: 1.25rem;
    max-width: 100%;
  }

  .content-text p:last-child { margin-bottom: 0; }

  /* Pricing */
  .pricing {
    background: #fff;
    padding: 1rem 0 4rem;
  }

  .pricing-title {
    font-size: 2rem;
    font-weight: 700;
    color: #000;
    letter-spacing: -0.5px;
    margin-bottom: 0.25rem;
  }

  .pricing-subtitle {
    color: #444;
    font-size: 1.05rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  /* Carousel */
  .carousel-wrapper {
    position: relative;
    margin-bottom: 1rem;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: 2px solid #000;
    background: #fff;
    color: #000;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    z-index: 10;
    flex-shrink: 0;
  }

  .carousel-btn--prev { left: -1.25rem; }
  .carousel-btn--next { right: -1.25rem; }

  .carousel-btn:hover {
    background: #c50066;
    color: #fff;
    border-color: #c50066;
  }

  .carousel-track { overflow: hidden; }

  .pricing-grid {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    align-items: stretch;
    padding-bottom: 6px;
  }

  .pricing-grid::-webkit-scrollbar { display: none; }

  /* Cards */
  .pricing-card {
    background: #fff;
    border: 2px solid #e0e0e0;
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
    flex: 0 0 260px;
    scroll-snap-align: start;
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
    overflow: hidden;
  }

  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .pricing-card--destaque {
    border-color: #c50066;
    border-width: 2px;
  }

  .destaque-badge {
    background: #c50066;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.75rem;
    text-align: center;
  }

  .card-body {
    padding: 1rem 1rem 0.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .plan-name {
    font-size: 1.6rem;
    font-weight: 700;
    color: #000;
    line-height: 1.1;
    margin: 0 0 0.85rem;
  }

  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 0 0 0.75rem;
    flex: 1;
  }

  .benefits-list li {
    color: #222;
    font-size: 0.875rem;
    font-weight: 500;
    padding-left: 1rem;
    position: relative;
    margin-bottom: 0.4rem;
    line-height: 1.4;
  }

  .benefits-list li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: #c50066;
    font-weight: 700;
  }

  .nota-12 {
    font-size: 0.75rem;
    color: #888;
    line-height: 1.4;
    margin: 0.25rem 0 0;
    font-style: italic;
  }

  .card-footer {
    padding: 0.75rem 1rem 0;
    border-top: 1px solid #f0f0f0;
    margin-top: 0.5rem;
  }

  .price-wrapper {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
  }

  .price {
    font-size: 2.4rem;
    font-weight: 700;
    color: #000;
    line-height: 1;
  }

  .price-label {
    font-size: 0.85rem;
    color: #888;
    font-weight: 400;
  }

  .btn {
    width: 100%;
    padding: 0.8rem 1.25rem;
    border: 2px solid #000;
    border-radius: 0.6rem;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    background: #fff;
    color: #000;
    transition: background 0.2s, color 0.2s;
    margin-bottom: 0.75rem;
  }

  .btn:hover {
    background: #000;
    color: #fff;
  }

  .btn--destaque {
    background: #c50066;
    color: #fff;
    border-color: #c50066;
  }

  .btn--destaque:hover {
    background: #a3005a;
    border-color: #a3005a;
  }

  /* Dots */
  .dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: #ddd;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }

  .dot--ativo {
    background: #c50066;
    transform: scale(1.25);
  }

  /* Free contribution */
  .free-contribution {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #000;
    border-radius: 1rem;
    padding: 1.5rem 1.75rem;
    text-decoration: none;
    transition: background 0.2s;
    color: #fff;
    gap: 1rem;
  }

  .free-contribution:hover { background: #1a1a1a; }

  .free-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.2rem;
  }

  .free-subtitle {
    font-size: 1rem;
    color: #aaa;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .container { padding: 0 1.25rem; }

    .hero { padding: 6rem 0 3.5rem; min-height: 380px; }

    .content { padding: 2.5rem 0; margin-top: -1.5rem; }
    .content-title { font-size: 1.5rem; }
    .content-text p { font-size: 1rem; }

    .pricing-title { font-size: 1.6rem; }
    .pricing-subtitle { font-size: 0.95rem; }

    .carousel-btn--prev { left: -0.75rem; }
    .carousel-btn--next { right: -0.75rem; }

    .pricing-card { flex: 0 0 calc(80vw - 1.5rem); }

    .free-title { font-size: 1.25rem; }
    .free-subtitle { font-size: 0.9rem; }
  }

  @media (max-width: 480px) {
    .container { padding: 0 1rem; }

    .hero { padding: 5rem 0 2.5rem; min-height: 320px; }

    .content { border-radius: 1.5rem 1.5rem 0 0; padding: 2rem 0; }

    .carousel-btn { display: none; }
    .pricing-card { flex: 0 0 calc(100vw - 3.5rem); }

    .plan-name { font-size: 1.4rem; }
    .price { font-size: 2rem; }

    .free-contribution { padding: 1.25rem; border-radius: 0.75rem; }
    .free-title { font-size: 1.1rem; }
  }
</style>

<script>
  const grid = document.getElementById("pricingGrid") as HTMLElement;
  const prevBtn = document.getElementById("prevBtn") as HTMLButtonElement;
  const nextBtn = document.getElementById("nextBtn") as HTMLButtonElement;
  const dotBtns = Array.from(document.querySelectorAll(".dot")) as HTMLButtonElement[];

  let currentIndex = 0;

  function getCards(): HTMLElement[] {
    return Array.from(grid.querySelectorAll(".pricing-card")) as HTMLElement[];
  }

  function getCardWidth(): number {
    const cards = getCards();
    if (!cards.length) return 260;
    const gap = parseFloat(getComputedStyle(grid).gap) || 20;
    return cards[0].offsetWidth + gap;
  }

  function atualizarDots(index: number) {
    dotBtns.forEach((d, i) => d.classList.toggle("dot--ativo", i === index));
  }

  function scrollToIndex(index: number): void {
    const count = getCards().length;
    currentIndex = ((index % count) + count) % count;
    grid.scrollTo({ left: currentIndex * getCardWidth(), behavior: "smooth" });
    atualizarDots(currentIndex);
  }

  nextBtn?.addEventListener("click", () => scrollToIndex(currentIndex + 1));
  prevBtn?.addEventListener("click", () => scrollToIndex(currentIndex - 1));

  dotBtns.forEach((btn, i) => btn.addEventListener("click", () => scrollToIndex(i)));

  grid.addEventListener("scrollend", () => {
    currentIndex = Math.round(grid.scrollLeft / getCardWidth());
    atualizarDots(currentIndex);
  });
</script>