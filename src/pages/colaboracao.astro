---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Colaboração — Paradoxo">
  <main>
    <section class="colaboracao-section">
      <div class="container">
        <div class="colaboracao-wrapper">
          <h1>Colabore com o Paradoxo</h1>
          <p class="subtitle">Sua contribuição faz a diferença!</p>

          <div class="content">
            <p>
              O Paradoxo é um espaço cultural independente que existe graças ao apoio da comunidade.
              Sua colaboração ajuda a manter nossas atividades e levar arte e cultura para todos.
            </p>

            <div class="pix-section">
              <div class="pix-header">
                <div class="pix-icon">
                  <svg width="32" height="32" viewBox="0 0 512 512" fill="currentColor">
                    <path d="M242.4 292.5C247.8 287.1 257.1 287.1 262.5 292.5L339.5 369.5C353.7 383.7 372.6 391.5 392.6 391.5H407.7L310.6 488.6C280.3 518.1 231.1 518.1 200.8 488.6L103.3 391.2H112.6C132.6 391.2 151.5 383.4 165.7 369.2L242.4 292.5zM262.5 218.9C257.1 224.4 247.8 224.4 242.4 218.9L165.7 142.2C151.5 128 132.6 120.2 112.6 120.2H103.3L200.4 23.05C230.7-7.359 279.9-7.359 310.2 23.05L407.7 120.5H392.6C372.6 120.5 353.7 128.3 339.5 142.5L262.5 218.9zM112.6 142.7C126.4 142.7 139.1 148.3 149.7 158.1L226.4 234.8C233.6 241.1 243 245.6 252.5 245.6C ## 245.6 261.9 241.1 278.4 234.8L201.7 311.5C## 318.1 178.9 323.7 165.2 323.7 151.4V142.7H112.6zM397.4 142.7H392.6C378.8 142.7 365.2 148.3 354.5 158.1L277.8 234.8C270.5 241.1 261.1 245.6 251.6 245.6C242.1 245.6 232.7 241.1 225.5 234.8L302.5 311.5C313.1 322.1 326.7 327.7 340.5 327.7H346.4L397.4 142.7z"/>
                  </svg>
                </div>
                <h2>Doe via PIX</h2>
              </div>

              <div class="pix-content">
                <div class="qr-container">
                  <div class="qr-wrapper">
                    <img 
                      src="https://res.cloudinary.com/ddpvact5z/image/upload/v1773279485/Paradoxo_-_Pix_ctavsv.png" 
                      alt="QR Code PIX para doação ao Paradoxo"
                      class="qr-image"
                    />
                  </div>
                  <p class="qr-instruction">Escaneie o QR Code com o app do seu banco</p>
                </div>

                <div class="divider">
                  <span>ou</span>
                </div>

                <div class="pix-key-section">
                  <p class="pix-key-label">Copie a chave PIX (CNPJ):</p>
                  <div class="key-display">
                    <span id="pixKey">49.759.501/0001-45</span>
                    <button id="copyBtn" class="copy-btn" title="Copiar chave PIX">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                      </svg>
                      <span class="btn-text">Copiar</span>
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <div class="outras-formas">
              <h3>Outras formas de colaborar</h3>
              <ul>
                <li>Participe de nossas oficinas e eventos</li>
                <li>Divulgue nosso trabalho nas redes sociais</li>
                <li>Seja voluntário em nossas atividades</li>
                <li>Doe materiais para nossas oficinas</li>
              </ul>
            </div>

            <a href="/livro-assinatura" class="back-btn">Livro de Assinatura</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    min-height: 100vh;
  }

  .colaboracao-section {
    background: linear-gradient(135deg, #C50066 0%, #9a0050 100%);
    padding: 3rem 1.5rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
  }

  .colaboracao-wrapper {
    background: white;
    border-radius: 20px;
    padding: 3rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
  }

  h1 {
    color: #C50066;
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    text-align: center;
  }

  .subtitle {
    color: #666;
    text-align: center;
    margin-bottom: 2rem;
    font-size: 1.125rem;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .content > p {
    color: #444;
    line-height: 1.7;
    font-size: 1.05rem;
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  /* PIX Section - Destaque */
  .pix-section {
    background: linear-gradient(135deg, #fdf2f8 0%, #fce7f3 100%);
    padding: 2.5rem;
    border-radius: 16px;
    border: 2px solid #f9a8d4;
  }

  .pix-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .pix-icon {
    background: #C50066;
    color: white;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pix-section h2 {
    color: #C50066;
    font-size: 1.75rem;
    font-weight: 800;
    margin: 0;
  }

  .pix-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  /* QR Code Container */
  .qr-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .qr-wrapper {
    background: white;
    padding: 1rem;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(197, 0, 102, 0.15);
    border: 3px solid #C50066;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .qr-wrapper:hover {
    transform: scale(1.02);
    box-shadow: 0 12px 40px rgba(197, 0, 102, 0.25);
  }

  .qr-image {
    display: block;
    width: 280px;
    height: 280px;
    object-fit: contain;
    border-radius: 8px;
  }

  .qr-instruction {
    color: #666;
    font-size: 0.95rem;
    text-align: center;
    font-weight: 500;
  }

  /* Divider */
  .divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 400px;
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #e5e5e5;
  }

  .divider span {
    color: #999;
    font-size: 0.875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* PIX Key Section */
  .pix-key-section {
    width: 100%;
    max-width: 400px;
  }

  .pix-key-label {
    color: #444;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
    text-align: center;
  }

  .key-display {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: white;
    padding: 1rem 1.25rem;
    border-radius: 12px;
    border: 2px solid #e5e5e5;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .key-display span#pixKey {
    flex: 1;
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
    font-size: 1rem;
    color: #333;
    font-weight: 500;
  }

  .copy-btn {
    background: #C50066;
    color: white;
    border: none;
    padding: 0.625rem 1rem;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.2s;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .copy-btn:hover {
    background: #a3004f;
    transform: translateY(-1px);
  }

  .copy-btn.copied {
    background: #10b981;
  }

  .btn-text {
    display: none;
  }

  /* Outras Formas */
  .outras-formas {
    padding: 1.5rem;
    background: #f9fafb;
    border-radius: 12px;
    border: 1px solid #e5e5e5;
  }

  .outras-formas h3 {
    color: #333;
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .outras-formas ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .outras-formas li {
    color: #555;
    padding-left: 1.75rem;
    position: relative;
    line-height: 1.6;
  }

  .outras-formas li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #C50066;
    font-weight: 700;
  }

  .back-btn {
    display: inline-block;
    background: white;
    color: #C50066;
    border: 2px solid #C50066;
    padding: 1rem 2rem;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s;
    align-self: center;
  }

  .back-btn:hover {
    background: #C50066;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(197, 0, 102, 0.35);
  }

  /* Responsivo */
  @media (min-width: 640px) {
    .qr-image {
      width: 320px;
      height: 320px;
    }

    .btn-text {
      display: inline;
    }

    .pix-section {
      padding: 3rem;
    }
  }

  @media (min-width: 768px) {
    .colaboracao-section {
      padding: 4rem 2rem;
    }

    .colaboracao-wrapper {
      padding: 3.5rem;
    }

    h1 {
      font-size: 2.5rem;
    }

    .qr-image {
      width: 340px;
      height: 340px;
    }
  }

  @media (max-width: 480px) {
    .colaboracao-section {
      padding: 1.5rem 1rem;
    }

    .colaboracao-wrapper {
      padding: 1.5rem;
      border-radius: 16px;
    }

    h1 {
      font-size: 1.5rem;
    }

    .pix-section {
      padding: 1.5rem;
    }

    .pix-header {
      flex-direction: column;
      gap: 0.75rem;
    }

    .pix-section h2 {
      font-size: 1.375rem;
    }

    .qr-image {
      width: 220px;
      height: 220px;
    }

    .key-display {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }

    .copy-btn {
      width: 100%;
      justify-content: center;
    }

    .btn-text {
      display: inline;
    }
  }
</style>

<script>
  const copyBtn = document.getElementById('copyBtn');
  const pixKey = document.getElementById('pixKey');

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(pixKey?.textContent || '');
      
      copyBtn.classList.add('copied');
      const originalHTML = copyBtn.innerHTML;
      copyBtn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg><span class="btn-text">Copiado!</span>';
      
      setTimeout(() => {
        copyBtn.classList.remove('copied');
        copyBtn.innerHTML = originalHTML;
      }, 2000);
    } catch (err) {
      // Fallback para navegadores mais antigos
      const textArea = document.createElement('textarea');
      textArea.value = pixKey?.textContent || '';
      document.body.appendChild(textArea);
      textArea.select();
      document.execCommand('copy');
      document.body.removeChild(textArea);
      
      copyBtn.classList.add('copied');
      setTimeout(() => copyBtn.classList.remove('copied'), 2000);
    }
  });
</script>
</Layout>
