---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Livro de Assinatura — Paradoxo Casa Atelier">
  <main>
    <!-- SPLASH SCREENS -->
    <div id="splashContainer" class="splash-container">
      <!-- Tela 1 - Boas vindas -->
      <section class="splash-screen active" data-screen="1">
        <div class="background-effects">
          <div class="circle circle-1"></div>
          <div class="circle circle-2"></div>
          <div class="circle circle-3"></div>
          <div class="circle circle-4"></div>
          <div class="circle circle-5"></div>
          <div class="color-bubble bubble-1"></div>
          <div class="color-bubble bubble-2"></div>
          <div class="color-bubble bubble-3"></div>
          <div class="color-bubble bubble-4"></div>
          <div class="sparkle sparkle-1"></div>
          <div class="sparkle sparkle-2"></div>
          <div class="sparkle sparkle-3"></div>
          <div class="sparkle sparkle-4"></div>
          <div class="sparkle sparkle-5"></div>
          <div class="sparkle sparkle-6"></div>
        </div>

        <div class="content">
          <div class="icon-wrapper bounce-in">
            <svg
              class="icon gift-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <rect x="3" y="8" width="18" height="4" rx="1"></rect>
              <path d="M12 8v13"></path>
              <path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"></path>
              <path
                d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"
              ></path>
            </svg>
          </div>

          <h1 class="title slide-up">Oie,<br />você veio!</h1>
          <p class="subtitle slide-up delay-1">Que bom ter você aqui</p>
          <p class="description slide-up delay-2">
            A gente preparou um presentinho especial...
          </p>
          <p class="highlight pulse delay-3">E ele já é seu!</p>

          <div class="progress-dots">
            <span class="dot active"></span>
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </div>

          <button class="next-btn slide-up delay-4" data-next="2">
            Próximo
            <svg
              class="btn-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </button>

          <button class="skip-btn fade-in delay-5" data-skip
            >Pular introdução</button
          >
        </div>
      </section>

      <!-- Tela 2 - Exclusividade -->
      <section class="splash-screen" data-screen="2">
        <div class="background-effects">
          <div class="circle circle-1"></div>
          <div class="circle circle-2"></div>
          <div class="circle circle-3"></div>
          <div class="circle circle-4"></div>
          <div class="circle circle-5"></div>
          <div class="color-bubble bubble-1"></div>
          <div class="color-bubble bubble-2"></div>
          <div class="color-bubble bubble-3"></div>
          <div class="color-bubble bubble-5"></div>
          <div class="disco-ball">
            <div class="disco-shine"></div>
          </div>
          <div class="sparkle sparkle-1"></div>
          <div class="sparkle sparkle-2"></div>
          <div class="sparkle sparkle-3"></div>
          <div class="sparkle sparkle-4"></div>
        </div>

        <div class="content">
          <div class="icon-wrapper bounce-in">
            <svg class="icon star-icon" viewBox="0 0 24 24" fill="currentColor">
              <polygon
                points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
              ></polygon>
            </svg>
          </div>

          <h1 class="title slide-up">Tem presente<br />pra você!</h1>
          <p class="subtitle slide-up delay-1">
            A gente preparou uma surpresa especial
          </p>
          <p class="description slide-up delay-2">E ela está te esperando...</p>
          <p class="highlight pulse delay-3">
            Leva menos de<br />1 minuto pra garantir!
          </p>

          <div class="progress-dots">
            <span class="dot"></span>
            <span class="dot active"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </div>

          <button class="next-btn slide-up delay-4" data-next="3">
            Próximo
            <svg
              class="btn-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </button>

          <button class="skip-btn fade-in delay-5" data-skip
            >Pular introdução</button
          >
        </div>
      </section>

      <!-- Tela 3 - O Paradoxo -->
      <section class="splash-screen" data-screen="3">
        <div class="background-effects">
          <div class="circle circle-1"></div>
          <div class="circle circle-2"></div>
          <div class="circle circle-3"></div>
          <div class="circle circle-4"></div>
          <div class="circle circle-5"></div>
          <div class="color-bubble bubble-1"></div>
          <div class="color-bubble bubble-2"></div>
          <div class="color-bubble bubble-4"></div>
          <div class="color-bubble bubble-6"></div>
          <div class="floating-star star-1"></div>
          <div class="floating-star star-2"></div>
          <div class="floating-star star-3"></div>
          <div class="sparkle sparkle-1"></div>
          <div class="sparkle sparkle-2"></div>
          <div class="sparkle sparkle-3"></div>
        </div>

        <div class="content">
          <div class="icon-wrapper bounce-in">
            <svg
              class="icon sparkles-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"
              ></path>
              <path d="M5 3v4"></path>
              <path d="M19 17v4"></path>
              <path d="M3 5h4"></path>
              <path d="M17 19h4"></path>
            </svg>
          </div>

          <h1 class="title slide-up brand-title">paradoxo</h1>
          <p class="subtitle slide-up delay-1 brand-subtitle">Casa Atelier</p>
          <p class="description slide-up delay-2">
            Arte, cultura e experiências que marcam
          </p>
          <p class="highlight pulse delay-3">
            Agradecemos por<br />você estar com a gente!
          </p>

          <div class="progress-dots">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot active"></span>
            <span class="dot"></span>
          </div>

          <button class="next-btn slide-up delay-4" data-next="4">
            Próximo
            <svg
              class="btn-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </button>

          <button class="skip-btn fade-in delay-5" data-skip
            >Pular introdução</button
          >
        </div>
      </section>

      <!-- Tela 4 - Chamada para ação -->
      <section class="splash-screen" data-screen="4">
        <div class="background-effects">
          <div class="circle circle-1"></div>
          <div class="circle circle-2"></div>
          <div class="circle circle-3"></div>
          <div class="circle circle-4"></div>
          <div class="circle circle-5"></div>
          <div class="color-bubble bubble-1"></div>
          <div class="color-bubble bubble-3"></div>
          <div class="color-bubble bubble-5"></div>
          <div class="color-bubble bubble-6"></div>
          <div class="heart-float heart-1"></div>
          <div class="heart-float heart-2"></div>
          <div class="heart-float heart-3"></div>
          <div class="sparkle sparkle-1"></div>
          <div class="sparkle sparkle-2"></div>
        </div>

        <div class="content">
          <div class="icon-wrapper bounce-in heart-icon-wrapper">
            <svg
              class="icon gift-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <rect x="3" y="8" width="18" height="4" rx="1"></rect>
              <path d="M12 8v13"></path>
              <path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"></path>
              <path
                d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"
              ></path>
            </svg>
          </div>

          <h1 class="title slide-up">Agora é sua vez!</h1>
          <p class="subtitle slide-up delay-1">
            Conta pra gente<br />o que você achou do Paradoxo?
          </p>
          <p class="description slide-up delay-2">É rapidinho, prometemos!</p>
          <p class="highlight pulse delay-3">
            E depois...<br />seu presente te espera!
          </p>

          <div class="progress-dots">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot active"></span>
          </div>

          <button class="next-btn cta-btn slide-up delay-4" data-show-form>
            Quero meu presente!
            <svg
              class="btn-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </button>
        </div>
      </section>
    </div>

    <!-- FORMULÁRIO -->
    <section id="formSection" class="form-section hidden">
      <div class="background-effects form-bg">
        <div class="circle circle-1"></div>
        <div class="circle circle-2"></div>
        <div class="circle circle-3"></div>
        <div class="color-bubble bubble-1"></div>
        <div class="color-bubble bubble-2"></div>
        <div class="color-bubble bubble-5"></div>
      </div>
      <div class="container">
        <div class="form-wrapper">
          <div class="form-badge">Seu presente te espera</div>
          <h1>Conta pra gente!</h1>
          <p class="form-subtitle">
            Responda rapidinho<br />e garanta seu presente
          </p>

          <form id="assinaturaForm" class="form">
            <div class="form-group">
              <label for="nome">Seu nome *</label>
              <input
                type="text"
                id="nome"
                name="nome"
                required
                placeholder="Digite seu nome completo"
              />
            </div>

            <div class="form-group">
              <label for="email">Seu e-mail *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="seu@email.com"
                pattern="^[A-Za-z0-9._%+-]{2,}@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$"
                title="Digite um e-mail válido (ex: nome@email.com)"
              />
            </div>

            <div class="form-group">
              <label for="gostou">O que você gostou?</label>
              <textarea
                id="gostou"
                name="gostou"
                rows="3"
                placeholder="Conte o que mais chamou sua atenção..."></textarea>
            </div>

            <div class="form-group">
              <label for="mensagem">Quer deixar uma mensagem?</label>
              <textarea
                id="mensagem"
                name="mensagem"
                rows="4"
                placeholder="Deixe sua mensagem para nós..."></textarea>
            </div>

            <div class="form-group">
              <label for="falar">Quer falar com a gente sobre algo?</label>
              <textarea
                id="falar"
                name="falar"
                rows="3"
                placeholder="Conte o que você gostaria de conversar..."
              ></textarea>
            </div>

            <div class="form-group">
              <label for="pergunta">Quer perguntar alguma coisa?</label>
              <textarea
                id="pergunta"
                name="pergunta"
                rows="3"
                placeholder="Faça sua pergunta..."></textarea>
            </div>

            <button type="submit" class="submit-btn">
              Garantir meu presente
            </button>
          </form>

          <div id="successMessage" class="success-message">
            <div class="success-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="64"
                height="64"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
            </div>
            <h2>Você acabou de desbloquear seu presente!</h2>
            <p class="success-text">
              O que você deixou aqui agora faz parte do Paradoxo.
            </p>

            <div class="promo-card">
              <div class="promo-badge">SÓ PRA VOCÊ</div>
              <h3>Só pra quem chegou até aqui</h3>
              <p class="promo-description">
                Chopp por apenas <strong>R$7,00</strong>
              </p>
              <div class="promo-instructions">
                <p>
                  Apresente esta tela na <strong>cozinha</strong> para resgatar seu
                  prêmio!
                </p>
              </div>
              <div class="promo-voucher">
                <span class="voucher-code">PRESENTE-PARADOXO</span>
                <span class="voucher-value">R$ 7,00</span>
              </div>
            </div>

            <div class="action-buttons">
              <a href="/amigos" class="colaborar-btn">
                Colaborar com o Paradoxo
              </a>
            </div>
          </div>

          <div id="duplicateMessage" class="duplicate-message">
            <div class="duplicate-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="64"
                height="64"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
              </svg>
            </div>
            <h2 id="duplicateTitle">Ops! Você já assinou nosso livro!</h2>
            <p id="duplicateReason" class="duplicate-text">
              Encontramos um cadastro com esse nome ou e-mail.
            </p>
            <p class="duplicate-subtext">
              Se você acha que isso é um erro, entre em contato conosco
            </p>
            <a href="mailto:contato@paradoxo.com" class="contact-btn">
              Entrar em contato
            </a>
            <div class="duplicate-actions">
              <a href="/colaboracao" class="colaborar-btn">
                Colaborar com o Paradoxo
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ===== ANIMAÇÕES BASE ===== */
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes bounceIn {
    0% {
      opacity: 0;
      transform: scale(0) rotate(-180deg);
    }
    50% {
      transform: scale(1.2) rotate(10deg);
    }
    100% {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }

  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.05);
      opacity: 0.9;
    }
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(5deg);
    }
  }

  @keyframes sparkle {
    0%,
    100% {
      opacity: 0;
      transform: scale(0) rotate(0deg);
    }
    50% {
      opacity: 1;
      transform: scale(1) rotate(180deg);
    }
  }

  @keyframes rotateCircle {
    from {
      transform: translate(-50%, -50%) rotate(0deg);
    }
    to {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }

  @keyframes rotateCircleReverse {
    from {
      transform: translate(-50%, -50%) rotate(360deg);
    }
    to {
      transform: translate(-50%, -50%) rotate(0deg);
    }
  }

  @keyframes scaleBreath {
    0%,
    100% {
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      transform: translate(-50%, -50%) scale(1.1);
    }
  }

  @keyframes disco {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  @keyframes discoShine {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.8;
    }
  }

  @keyframes heartBeat {
    0%,
    100% {
      transform: scale(1);
    }
    14% {
      transform: scale(1.3);
    }
    28% {
      transform: scale(1);
    }
    42% {
      transform: scale(1.3);
    }
    70% {
      transform: scale(1);
    }
  }

  @keyframes floatHeart {
    0% {
      opacity: 0;
      transform: translateY(100px) scale(0);
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translateY(-100vh) scale(1);
    }
  }

  @keyframes starTwinkle {
    0%,
    100% {
      opacity: 0.3;
      transform: scale(0.8) rotate(0deg);
    }
    50% {
      opacity: 1;
      transform: scale(1.2) rotate(180deg);
    }
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes slideOut {
    from {
      opacity: 1;
      transform: scale(1);
    }
    to {
      opacity: 0;
      transform: scale(1.05);
    }
  }

  /* ===== ESTRUTURA PRINCIPAL ===== */
  main {
    min-height: 100vh;
    overflow: hidden;
  }

  .splash-container {
    position: relative;
    min-height: 100vh;
    background: #c50066;
  }

  .splash-screen {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.5s ease,
      visibility 0.5s ease;
  }

  .splash-screen.active {
    opacity: 1;
    visibility: visible;
  }

  .splash-screen.exit {
    animation: slideOut 0.5s ease forwards;
  }

  .splash-screen.enter {
    animation: slideIn 0.5s ease forwards;
  }

  /* ===== EFEITOS DE BACKGROUND ===== */
  .background-effects {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .circle {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.1);
  }

  .circle-1 {
    width: 600px;
    height: 600px;
    animation: rotateCircle 20s linear infinite;
  }

  .circle-2 {
    width: 400px;
    height: 400px;
    border-color: rgba(255, 255, 255, 0.15);
    animation: rotateCircleReverse 15s linear infinite;
  }

  .circle-3 {
    width: 200px;
    height: 200px;
    border-color: rgba(255, 255, 255, 0.2);
    animation: scaleBreath 8s ease-in-out infinite;
  }

  .circle-4 {
    width: 750px;
    height: 750px;
    border-width: 3px;
    border-color: rgba(255, 255, 255, 0.08);
    animation: rotateCircle 30s linear infinite;
  }

  .circle-5 {
    width: 900px;
    height: 900px;
    border-width: 4px;
    border-color: rgba(255, 255, 255, 0.05);
    animation: rotateCircleReverse 40s linear infinite;
  }

  /* Círculos/Bolhas coloridas */
  .color-bubble {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.6;
    animation: bubbleFloat 8s ease-in-out infinite;
  }

  .bubble-1 {
    width: 200px;
    height: 200px;
    background: #ff3399;
    top: -50px;
    right: -50px;
    animation-delay: 0s;
  }

  .bubble-2 {
    width: 180px;
    height: 180px;
    background: #ffcc00;
    bottom: 10%;
    left: -40px;
    animation-delay: 2s;
  }

  .bubble-3 {
    width: 150px;
    height: 150px;
    background: #00ccff;
    top: 30%;
    right: -30px;
    animation-delay: 4s;
  }

  .bubble-4 {
    width: 120px;
    height: 120px;
    background: #9933ff;
    bottom: 20%;
    right: 20%;
    animation-delay: 1s;
  }

  .bubble-5 {
    width: 160px;
    height: 160px;
    background: #ff6600;
    top: 60%;
    left: 5%;
    animation-delay: 3s;
  }

  .bubble-6 {
    width: 140px;
    height: 140px;
    background: #33ff99;
    top: 10%;
    left: 20%;
    animation-delay: 5s;
  }

  @keyframes bubbleFloat {
    0%,
    100% {
      transform: translateY(0) scale(1);
      opacity: 0.5;
    }
    50% {
      transform: translateY(-30px) scale(1.1);
      opacity: 0.7;
    }
  }

  .sparkle {
    position: absolute;
    width: 8px;
    height: 8px;
    background: white;
    border-radius: 50%;
    animation: sparkle 3s ease-in-out infinite;
  }

  .sparkle-1 {
    top: 15%;
    left: 20%;
    animation-delay: 0s;
  }
  .sparkle-2 {
    top: 25%;
    right: 15%;
    animation-delay: 0.5s;
  }
  .sparkle-3 {
    bottom: 30%;
    left: 10%;
    animation-delay: 1s;
  }
  .sparkle-4 {
    bottom: 20%;
    right: 25%;
    animation-delay: 1.5s;
  }
  .sparkle-5 {
    top: 40%;
    left: 5%;
    animation-delay: 2s;
  }
  .sparkle-6 {
    top: 60%;
    right: 8%;
    animation-delay: 2.5s;
  }

  .disco-ball {
    position: absolute;
    top: 10%;
    right: 10%;
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #e0e0e0 0%, #ffffff 50%, #c0c0c0 100%);
    border-radius: 50%;
    animation: disco 4s linear infinite;
    box-shadow:
      0 0 20px rgba(255, 255, 255, 0.5),
