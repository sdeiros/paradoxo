---
import Layout from "../../../layouts/Layout.astro";
import { exposicoes } from "../index.astro";

export function getStaticPaths() {
    return exposicoes.map((expo) => ({
        params: { slug: expo.slug },
        props: { expo },
    }));
}

const { expo } = Astro.props;

// Reúne todas as imagens de todos os blocos de galeria
const todasImagens: { src: string; legenda?: string }[] = (expo.blocos ?? [])
    .filter((b: any) => b.tipo === "galeria")
    .flatMap((b: any) => b.imagens);
---

<Layout title={`Fotos — ${expo.titulo} — Paradoxo Casa Atelier`}>
    <section class="hero" style={`background-image: url('${expo.imagem}')`}>
        <div class="hero-overlay"></div>
        <div class="hero-container">
            <a href={`/exposicoes/${expo.slug}`} class="back-link">
                <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="M19 12H5M12 5l-7 7 7 7"></path>
                </svg>
                Voltar para a exposição
            </a>
            <p class="hero-tipo">{expo.tipo}</p>
            <h1>{expo.titulo}</h1>
            <p class="hero-sub">
                Todas as fotos · {todasImagens.length} imagens
            </p>
        </div>
    </section>

    <section class="content-wrapper">
        <div class="content-section">
            <div class="container">
                <div class="fotos-grid">
                    {
                        todasImagens.map((img, idx) => (
                            <figure class="foto-item">
                                <button
                                    class="lb-trigger"
                                    data-src={img.src}
                                    data-alt={img.legenda || ""}
                                    data-index={idx}
                                    aria-label="Ver imagem ampliada"
                                >
                                    <img
                                        src={img.src}
                                        alt={img.legenda || ""}
                                        loading="lazy"
                                    />
                                    <span class="lb-hint" aria-hidden="true">
                                        <svg
                                            width="20"
                                            height="20"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2.5"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />
                                        </svg>
                                    </span>
                                </button>
                                {img.legenda && (
                                    <figcaption>{img.legenda}</figcaption>
                                )}
                            </figure>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>
</Layout>

<!-- Lightbox -->
<dialog id="lightbox" aria-label="Visualizar imagem">
    <button id="lb-close" aria-label="Fechar">
        <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </button>
    <button id="lb-prev" aria-label="Imagem anterior">
        <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <path d="M15 18l-6-6 6-6"></path>
        </svg>
    </button>
    <div id="lb-img-wrap">
        <img id="lb-img" src="" alt="" />
    </div>
    <button id="lb-next" aria-label="Próxima imagem">
        <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <path d="M9 18l6-6-6-6"></path>
        </svg>
    </button>
    <p id="lb-caption"></p>
    <p id="lb-counter"></p>
</dialog>

<script>
    const dialog = document.getElementById("lightbox") as HTMLDialogElement;
    const lbImg = document.getElementById("lb-img") as HTMLImageElement;
    const lbCap = document.getElementById("lb-caption") as HTMLParagraphElement;
    const lbCounter = document.getElementById(
        "lb-counter",
    ) as HTMLParagraphElement;
    const lbClose = document.getElementById("lb-close") as HTMLButtonElement;
    const lbPrev = document.getElementById("lb-prev") as HTMLButtonElement;
    const lbNext = document.getElementById("lb-next") as HTMLButtonElement;

    const triggers = Array.from(
        document.querySelectorAll<HTMLButtonElement>(".lb-trigger"),
    );
    let currentIndex = 0;

    function goTo(index: number) {
        currentIndex = (index + triggers.length) % triggers.length;
        const btn = triggers[currentIndex];
        lbImg.src = btn.dataset.src || "";
        lbImg.alt = btn.dataset.alt || "";
        lbCap.textContent = btn.dataset.alt || "";
        lbCap.style.display = btn.dataset.alt ? "block" : "none";
        lbCounter.textContent = `${currentIndex + 1} / ${triggers.length}`;
        lbPrev.style.display = triggers.length > 1 ? "flex" : "none";
        lbNext.style.display = triggers.length > 1 ? "flex" : "none";
    }

    function openLightbox(index: number) {
        goTo(index);
        dialog.showModal();
        document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
        dialog.close();
        lbImg.src = "";
        document.body.style.overflow = "";
    }

    triggers.forEach((btn, idx) => {
        btn.addEventListener("click", () => openLightbox(idx));
    });

    lbClose.addEventListener("click", closeLightbox);
    lbPrev.addEventListener("click", () => goTo(currentIndex - 1));
    lbNext.addEventListener("click", () => goTo(currentIndex + 1));

    dialog.addEventListener("click", (e) => {
        if (e.target === dialog) closeLightbox();
    });
    dialog.addEventListener("close", () => {
        document.body.style.overflow = "";
    });

    document.addEventListener("keydown", (e) => {
        if (!dialog.open) return;
        if (e.key === "ArrowRight") goTo(currentIndex + 1);
        if (e.key === "ArrowLeft") goTo(currentIndex - 1);
        if (e.key === "Escape") closeLightbox();
    });
</script>

<style>
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    /* Hero */
    .hero {
        position: relative;
        background-color: #000;
        background-size: cover;
        background-position: center;
        padding: 6rem 0 4rem;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(0, 0, 0, 0.55) 0%,
            rgba(0, 0, 0, 0.75) 100%
        );
        z-index: 0;
    }

    .hero-container {
        position: relative;
        z-index: 1;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: #fff;
    }

    .hero-tipo {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #c50066;
        margin: 0 0 0.5rem;
    }

    .hero h1 {
        color: #fff;
        font-size: clamp(2rem, 4vw, 3.5rem);
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: -1px;
        margin: 0 0 0.5rem;
    }

    .hero-sub {
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.95rem;
        font-weight: 500;
        margin: 0;
    }

    /* Content */
    .content-wrapper {
        background: #000;
    }

    .content-section {
        background: #fff;
        border-radius: 2rem 2rem 0 0;
        margin-top: -2rem;
        padding: 4rem 0 6rem;
    }

    /* Grid de fotos */
    .fotos-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }

    .foto-item {
        margin: 0;
        border-radius: 0.75rem;
        overflow: hidden;
        border: 2px solid #000;
        position: relative;
    }

    .foto-item button {
        display: block;
        width: 100%;
        padding: 0;
        border: none;
        background: none;
        cursor: pointer;
        position: relative;
    }

    .foto-item img {
        width: 100%;
        height: 280px;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
    }

    .foto-item:hover img {
        transform: scale(1.04);
    }

    figcaption {
        font-size: 0.8rem;
        color: #666;
        font-weight: 500;
        padding: 0.5rem 0.75rem;
        text-align: center;
    }

    /* Hint de zoom */
    .lb-hint {
        position: absolute;
        bottom: 0.6rem;
        right: 0.6rem;
        background: rgba(0, 0, 0, 0.55);
        color: #fff;
        border-radius: 50%;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s;
    }

    .foto-item button:hover .lb-hint {
        opacity: 1;
    }

    /* Lightbox */
    #lightbox {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        max-width: 100%;
        max-height: 100%;
        background: rgba(0, 0, 0, 0);
        border: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        display: none; /* 👈 ESSENCIAL */
    }

    #lightbox[open] {
        display: flex; /* 👈 só aparece quando abre */

        background: rgba(0, 0, 0, 0.795);
    }

    #lb-close {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        background: rgba(255, 255, 255, 0.12);
        border: none;
        color: #fff;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.2s;
        z-index: 10;
    }

    #lb-close:hover {
        background: rgba(255, 255, 255, 0.25);
    }

    #lb-prev,
    #lb-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255, 255, 255, 0.12);
        border: none;
        color: #fff;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.2s;
        z-index: 10;
    }

    #lb-prev {
        left: 1.25rem;
    }
    #lb-next {
        right: 1.25rem;
    }

    #lb-prev:hover,
    #lb-next:hover {
        background: rgba(255, 255, 255, 0.25);
    }

    #lb-img-wrap {
        max-width: 80vw;
        max-height: 82vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    #lb-img {
        max-width: 80vw;
        max-height: 78vh;
        object-fit: contain;
        border-radius: 0.5rem;
        transition: opacity 0.15s ease;
    }

    #lb-caption {
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.9rem;
        margin-top: 0.75rem;
        text-align: center;
    }

    #lb-counter {
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.8rem;
        margin-top: 0.25rem;
        text-align: center;
    }

    @media (max-width: 768px) {
        .container {
            padding: 0 1.25rem;
        }

        .fotos-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .foto-item img {
            height: 200px;
        }
    }

    @media (max-width: 480px) {
        .fotos-grid {
            grid-template-columns: 1fr;
        }

        .foto-item img {
            height: 260px;
        }
    }
</style>
