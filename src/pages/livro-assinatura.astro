<script>
  // Navegação entre telas splash
  const splashContainer = document.getElementById("splashContainer");
  const formSection = document.getElementById("formSection");
  const screens = document.querySelectorAll(".splash-screen");
  let currentScreen = 1;

  // Função para navegar para próxima tela
  function goToScreen(screenNumber: number) {
    const current = document.querySelector(
      `.splash-screen[data-screen="${currentScreen}"]`,
    );
    const next = document.querySelector(
      `.splash-screen[data-screen="${screenNumber}"]`,
    );

    if (current && next) {
      current.classList.remove("active");
      current.classList.add("exit");

      setTimeout(() => {
        current.classList.remove("exit");
        next.classList.add("active", "enter");

        setTimeout(() => {
          next.classList.remove("enter");
        }, 500);
      }, 300);

      currentScreen = screenNumber;
    }
  }

  // Função para mostrar formulário
  function showForm() {
    if (splashContainer && formSection) {
      splashContainer.style.opacity = "0";
      splashContainer.style.transition = "opacity 0.5s ease";

      setTimeout(() => {
        splashContainer.style.display = "none";
        formSection.classList.remove("hidden");
      }, 500);
    }
  }

  // Event listeners para botões "Próximo"
  document.querySelectorAll("[data-next]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const nextScreen = parseInt(btn.getAttribute("data-next") || "1");
      goToScreen(nextScreen);
    });
  });

  // Event listener para botão "Vamos lá!"
  document.querySelectorAll("[data-show-form]").forEach((btn) => {
    btn.addEventListener("click", showForm);
  });

  // Event listeners para botões "Pular"
  document.querySelectorAll("[data-skip]").forEach((btn) => {
    btn.addEventListener("click", showForm);
  });

  // ===== LÓGICA DO FORMULÁRIO =====
  const form = document.getElementById("assinaturaForm") as HTMLFormElement;
  const successMessage = document.getElementById("successMessage");
  const duplicateMessage = document.getElementById("duplicateMessage");
  const submitBtn = form?.querySelector(".submit-btn") as HTMLButtonElement;

  const APPS_SCRIPT_URL =
    "https://script.google.com/macros/s/AKfycbx953Z5rjwS6UECXA8wGSYEMWcwmmY7TNYY6-jDuR6BAdOVmEKFY53_NBonanBSFRMt/exec";

  async function checkUserExists(
    nome: string,
    email: string,
  ): Promise<{ exists: boolean; reason?: string }> {
    try {
      const response = await fetch(
        `${APPS_SCRIPT_URL}?action=checkEmail&nome=${encodeURIComponent(nome)}&email=${encodeURIComponent(email)}`,
      );
      const result = await response.json();
      return { exists: result.exists === true, reason: result.reason };
    } catch (error) {
      return { exists: false };
    }
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    const nome = data.nome as string;
    const email = data.email as string;

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Verificando...";
    }

    try {
      const checkResult = await checkUserExists(nome, email);

      if (checkResult.exists) {
        const duplicateTitle = document.getElementById("duplicateTitle");
        const duplicateReason = document.getElementById("duplicateReason");

        if (checkResult.reason === "nome") {
          if (duplicateTitle)
            duplicateTitle.textContent = "Ops! Este nome já foi cadastrado!";
          if (duplicateReason)
            duplicateReason.textContent =
              "Já existe uma assinatura com esse nome no nosso livro.";
        } else if (checkResult.reason === "email") {
          if (duplicateTitle)
            duplicateTitle.textContent = "Ops! Este e-mail já foi cadastrado!";
          if (duplicateReason)
            duplicateReason.textContent =
              "Já existe uma assinatura com esse e-mail no nosso livro.";
        }

        form.style.display = "none";
        duplicateMessage?.classList.add("show");
        return;
      }

      if (submitBtn) {
        submitBtn.textContent = "Enviando...";
      }

      const timestamp = new Date().toLocaleString("pt-BR", {
        timeZone: "America/Sao_Paulo",
      });

      const dataCompleta = {
        ...data,
        timestamp,
      };

      await fetch(APPS_SCRIPT_URL, {
        method: "POST",
        mode: "no-cors",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(dataCompleta),
      });

      form.style.display = "none";
      successMessage?.classList.add("show");
    } catch (error) {
      alert("Erro ao enviar. Tente novamente.");

      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "Enviar Assinatura";
      }
    }
  });
</script>
